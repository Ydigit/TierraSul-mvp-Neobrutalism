# =============================================================================
# Top-level .gitignore — safety net for the whole repo.
# Project-specific ignores (Next.js, Python, etc.) live in each app folder.
# =============================================================================

# --- OS / Filesystem ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db
*~

# --- Editors & IDEs ----------------------------------------------------------
.idea/
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*.tmp

# --- Logs --------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment & secrets (NEVER commit these) ------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
.secrets/
secrets.json

# --- Dependency directories --------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/cache
.yarn/install-state.gz
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.tox/

# --- Build / output ----------------------------------------------------------
dist/
build/
out/
.next/
.turbo/
.cache/
.parcel-cache/
coverage/
*.tsbuildinfo
next-env.d.ts

# --- Hosting / infrastructure ------------------------------------------------
.vercel
.netlify
.firebase/

# --- Test artefacts ----------------------------------------------------------
junit.xml
playwright-report/
test-results/

# --- Playwright MCP / UI audit crawl output ----------------------------------
.playwright-mcp/
.ui-audit/

# --- Misc --------------------------------------------------------------------
.history/
